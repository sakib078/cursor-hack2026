# Copy to .env and fill in. Required for the chat to work.
ANTHROPIC_API_KEY=sk-ant-...
ELEVENLABS_API_KEY=...

# Optional overrides
# CLAUDE_MODEL=claude-sonnet-4-6
# ELEVENLABS_MODEL=eleven_turbo_v2
# CORS_ORIGINS=http://localhost:5173,http://127.0.0.1:5173

# DEV ONLY — lets you create a test session without the upload page.
# Remove once teammates' Steps 1-2 are wired in.
# AFTERWORDS_DEV_SEED=1
# DEV_VOICE_ID=        # a real ElevenLabs voice id to actually hear audio
